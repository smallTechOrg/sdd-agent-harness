AGENT_DATABASE_URL=sqlite:///./data/agent.db

# LLM provider — auto-detected from whichever key is set below.
# Override explicitly: anthropic | gemini
# AGENT_LLM_PROVIDER=anthropic

# Model — this project pins the CHEAP Gemini model (cost is a dealbreaker).
# Do NOT use gemini-2.5-pro (too expensive for this personal tool).
AGENT_LLM_MODEL=gemini-2.5-flash

# Set the Gemini provider key (this project uses Gemini):
AGENT_GEMINI_API_KEY=
# AGENT_ANTHROPIC_API_KEY=   # unused in this project

# Max upload size for CSVs (MB):
AGENT_MAX_UPLOAD_MB=25

PORT=8001
