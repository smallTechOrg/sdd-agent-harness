# Data Analysis Agent — environment variables
# Copy to .env and fill in the values (this file is safe to commit; .env is gitignored)

# ─── Database ───────────────────────────────────────────────────────────────
# SQLite database file path (relative to repo root)
AGENT_DATABASE_URL=sqlite:///./data_analysis.db

# ─── LLM provider ────────────────────────────────────────────────────────────
# Required: Gemini 2.5 Flash
AGENT_GEMINI_API_KEY=

# Optional overrides
# AGENT_LLM_PROVIDER=gemini
# AGENT_LLM_MODEL=gemini-2.5-flash

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8001

# ─── Observability (optional — app runs without these) ───────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=data-analysis-agent

# ─── Cost tracking (Gemini 2.5 Flash rates, USD per 1k tokens) ───────────────
# AGENT_COST_INPUT_PER_1K=0.000125
# AGENT_COST_OUTPUT_PER_1K=0.000375
