# =========================================================
# Data Analysis Agent — Environment Variables
# Copy to .env and fill in your real values.
# .env is gitignored and must NEVER be committed.
# =========================================================

# --- App Database (SQLite — app metadata only) ---
AGENT_DATABASE_URL=sqlite:///./data/agent.db

# --- LLM Provider: Gemini ---
AGENT_GEMINI_API_KEY=          # Required — your Google Gemini API key

# --- Model overrides (defaults shown) ---
AGENT_LLM_MODEL_PLAN=gemini-2.5-flash    # Node: plan_analysis  (low-latency code gen)
AGENT_LLM_MODEL_REASON=gemini-2.5-pro   # Node: reason_answer  (high-quality reasoning)

# --- PostgreSQL external data source (Phase 2) ---
# POSTGRES_DSN=postgresql://user:password@localhost:5432/mydb

# --- LangSmith observability (optional but recommended) ---
# Note: LangGraph reads LANGCHAIN_* env vars directly (no AGENT_ prefix)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=           # Your LangSmith API key
# LANGCHAIN_PROJECT=data-analysis-agent

# --- Server ---
PORT=8001
