# DataChat — Environment Variables
# Copy this file to .env and fill in your values.
# All commands run from the repo root.

# --- Required ---
DATACHAT_DATABASE_URL=sqlite:///./datachat.db
DATACHAT_GEMINI_API_KEY=your-gemini-api-key-here

# --- Optional ---
DATACHAT_LLM_MODEL=gemini-2.5-flash
DATACHAT_MAX_ITERATIONS=10
DATACHAT_MAX_UPLOAD_BYTES=52428800
DATACHAT_LOG_LEVEL=INFO
PORT=8001
