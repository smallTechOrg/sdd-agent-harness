# === Database (SQLite is the production DB for this single-user app) ===
AGENT_DATABASE_URL=sqlite:///./data/agent.db
# Optional separate DB for tests (tests otherwise use an isolated temp SQLite file)
# AGENT_TEST_DATABASE_URL=sqlite:///./data/test.db

# === LLM provider ===
# Provider auto-detected from whichever key is set below (gemini here).
# Override explicitly if needed: anthropic | gemini
# AGENT_LLM_PROVIDER=gemini

# Working model. This workbench defaults to the cheap model for low cost;
# leave set to gemini-2.5-flash. Hard questions escalate to gemini-2.5-pro (Phase 4).
AGENT_LLM_MODEL=gemini-2.5-flash

# === Provider key (set the Gemini key) ===
AGENT_GEMINI_API_KEY=
# AGENT_ANTHROPIC_API_KEY=

PORT=8001
