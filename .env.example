# === Database ===
AGENT_DATABASE_URL=sqlite:///./data/agent.db

# === LLM provider (Gemini) ===
# Provider auto-detected from whichever key is set. Override: anthropic | gemini
# AGENT_LLM_PROVIDER=gemini
AGENT_GEMINI_API_KEY=
AGENT_ANTHROPIC_API_KEY=

# Gemini model — cheap/fast tier (cost is a stated constraint)
# AGENT_GEMINI_MODEL=gemini-2.5-flash

# === Agent loop ===
# Bounded plan->generate->execute->inspect->refine step limit
# AGENT_MAX_STEPS=6

# === Dataset store (uploaded files live here, never in the LLM) ===
# AGENT_DATASET_STORE_DIR=data/datasets

# === Cost meter (Gemini per-1K-token pricing in USD; keeps cost accurate w/o code change) ===
# AGENT_COST_PER_1K_IN=0.00015
# AGENT_COST_PER_1K_OUT=0.0006

# === Server ===
PORT=8001
