# Copy to .env and fill in. All vars are read by pydantic-settings with the ANALYST_ prefix
# (see src/config.py). The server runs FULLY OFFLINE with no key — a key is only needed
# for a real LLM run (POST /runs against a live provider).

# --- Runtime LLM (the product's model) -----------------------------------------------
ANALYST_LLM_PROVIDER=google_genai
ANALYST_LLM_MODEL=gemini-2.5-flash
# Required only for a real LLM run. Leave blank for stub/offline mode (server boots,
# /health returns stub_mode: true, offline tests pass).
ANALYST_LLM_API_KEY=

# --- Persistence ---------------------------------------------------------------------
# SQLAlchemy async URL for the metadata spine (local SQLite; swap to Postgres on deploy).
ANALYST_DATABASE_URL=sqlite+aiosqlite:///./analyst.db
# Directory holding the per-dataset DuckDB analytics files.
ANALYST_DATA_DIR=./data

# --- Serving -------------------------------------------------------------------------
ANALYST_PORT=8001

# --- Optional tuning (defaults in src/config.py) -------------------------------------
# ANALYST_MAX_ITERATIONS=12
# ANALYST_MAX_QUERY_ROWS=1000
# ANALYST_QUERY_TIMEOUT_S=15.0
# ANALYST_DURABILITY_ENABLED=false
