# ── DataChat environment ───────────────────────────────────────────────
# Copy to .env and fill in AGENT_GEMINI_API_KEY. .env is gitignored.

# Database (SQLite is the production DB for this single local owner)
AGENT_DATABASE_URL=sqlite:///./data/agent.db

# ── LLM provider: Google Gemini ────────────────────────────────────────
# Provider is auto-detected from whichever key is set; for DataChat set the
# Gemini key. Default model is the low-cost gemini-2.5-flash (honors the
# cost constraint). NOTE: gemini-2.0-flash is the spec's intended default but
# is currently rejected (404 'no longer available') for new keys, so DataChat
# defaults to gemini-2.5-flash. Override with AGENT_LLM_MODEL.
AGENT_GEMINI_API_KEY=
AGENT_LLM_MODEL=gemini-2.5-flash
# AGENT_LLM_PROVIDER=gemini   # optional explicit override (auto-detected otherwise)

# Anthropic is unused by DataChat — leave blank.
AGENT_ANTHROPIC_API_KEY=

# ── Gemini pricing (USD per 1M tokens) — used to compute per-question cost ─
# Defaults reflect gemini-2.5-flash list pricing; adjust if your model differs.
AGENT_PRICE_INPUT_PER_M=0.10
AGENT_PRICE_OUTPUT_PER_M=0.40

# ── Privacy / context budget ───────────────────────────────────────────
# Max sample rows sent to the LLM (full data NEVER leaves the machine).
AGENT_SAMPLE_ROWS=20
# Conversation turns of history fed back into the prompt.
AGENT_HISTORY_TURNS=6

# ── Local code execution (sandbox) ─────────────────────────────────────
AGENT_EXEC_TIMEOUT_S=30
AGENT_MAX_RETRIES=1

# ── Uploads ────────────────────────────────────────────────────────────
AGENT_MAX_UPLOAD_MB=100

# ── Logging ────────────────────────────────────────────────────────────
AGENT_LOG_LEVEL=INFO

# ── Optional: LangSmith tracing (leave blank to disable) ───────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=

# Server port
PORT=8001
