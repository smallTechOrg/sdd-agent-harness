AGENT_DATABASE_URL=sqlite:///./data/app.db

# DuckDB file holding ingested dataset rows (data store; metadata stays in AGENT_DATABASE_URL)
AGENT_DUCKDB_PATH=./data/analytics.duckdb

# Token-economy cap: max sample rows ever sent to the LLM per dataset
AGENT_MAX_SAMPLE_ROWS=5

# LLM provider — auto-detected from whichever key is set below.
# Override explicitly: anthropic | gemini
# AGENT_LLM_PROVIDER=anthropic

# Override model (uses provider default when blank):
# AGENT_LLM_MODEL=claude-sonnet-4-6   (Anthropic default)
# AGENT_LLM_MODEL=gemini-2.5-flash      (Gemini default)

# Set exactly ONE provider key:
AGENT_ANTHROPIC_API_KEY=
AGENT_GEMINI_API_KEY=

PORT=8001
