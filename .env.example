# ── Data Analysis Agent — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in the required values.
# .env is gitignored and never committed.

# Database (SQLite — local file; directory must exist before first run)
AGENT_DATABASE_URL=sqlite:///./data/agent.db

# LLM provider — auto-detected from whichever key is set below.
# Override explicitly: gemini | anthropic
AGENT_LLM_PROVIDER=gemini

# LLM model — uses provider default when blank
AGENT_LLM_MODEL=gemini-2.5-pro

# Gemini API key — REQUIRED for Phase 3+ NL query. Phases 1–2 work without it.
AGENT_GEMINI_API_KEY=

# Anthropic API key — optional alternative provider (not used by default)
AGENT_ANTHROPIC_API_KEY=

# Server port
PORT=8001
