# Senior Data Analyst Agent — environment variables
# Copy to .env and fill in. All vars are prefixed DATA_ANALYST_.

# SQLite metadata store (sessions, datasets registry, messages, audit log)
DATA_ANALYST_DATABASE_URL=sqlite:///./data/metadata.db

# DuckDB analytical engine (stores uploaded datasets, runs analytical SQL)
DATA_ANALYST_DUCKDB_PATH=./data/datasets.duckdb

# Google Gemini API key. Leave blank to run in offline STUB mode (UI shows a banner).
# When set, provider=auto resolves to real Gemini automatically.
DATA_ANALYST_GEMINI_API_KEY=

# LLM provider: auto | gemini | stub  (auto = real when key set, else stub)
DATA_ANALYST_LLM_PROVIDER=auto

# Models: cheap default for NL->SQL, escalation model for complex reasoning
DATA_ANALYST_LLM_MODEL=gemini-2.5-flash
DATA_ANALYST_LLM_MODEL_ESCALATION=gemini-2.5-pro

# Token economy: number of sample rows per dataset sent to the LLM (never raw data)
DATA_ANALYST_SAMPLE_ROWS=5

# Web server
DATA_ANALYST_PORT=8001
DATA_ANALYST_LOG_LEVEL=INFO
