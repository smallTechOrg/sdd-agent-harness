# === Local Data Analyst — configuration ===
# Copy to `.env` and fill AGENT_GEMINI_API_KEY. `.env` is gitignored; never commit it.

# App state / history (SQLite — production driver here IS SQLite)
AGENT_DATABASE_URL=sqlite:///./data/agent.db

# --- LLM provider (Gemini, cheap Flash tier for low cost) ---
# Provider auto-detected from whichever key is set; override with AGENT_LLM_PROVIDER.
# AGENT_LLM_PROVIDER=gemini
# Flash-tier model keeps cost low (default below). Override if needed.
AGENT_LLM_MODEL=gemini-2.5-flash

# Set your Gemini key here (the one manual setup step):
AGENT_GEMINI_API_KEY=
# (Anthropic supported by the skeleton but unused for this build.)
AGENT_ANTHROPIC_API_KEY=

# --- Privacy boundary ---
# Max sample rows sent to the LLM (schema + these rows only; full data stays local).
AGENT_SAMPLE_ROWS=10

# --- Cost guard (hard step cap) ---
# Max reasoning/execution steps per question; cap-hit warns instead of spending freely.
AGENT_MAX_STEPS=5
# Max rows returned from any local analysis step (bounded aggregates only).
AGENT_MAX_RESULT_ROWS=1000

# --- Cost accounting (Gemini Flash pricing, USD per 1M tokens) ---
AGENT_PRICE_IN_PER_M=0.30
AGENT_PRICE_OUT_PER_M=2.50

# --- Upload limits ---
AGENT_MAX_UPLOAD_MB=100

LOG_LEVEL=INFO
PORT=8001
