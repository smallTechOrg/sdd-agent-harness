# Version control
.git/
.gitignore

# Python bytecode and caches
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/

# Local secrets and config
.env
.env.*
!.env.example

# Runtime data (never bake into image — mount a volume)
*.db
uploads/
logs/
htmlcov/
.coverage

# Tests (not needed in production image)
tests/

# Dev tooling and docs
*.md
reports/
spec/
.claude/
.github/

# macOS
.DS_Store
